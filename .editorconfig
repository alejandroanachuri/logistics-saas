# EditorConfig is awesome: https://EditorConfig.org
# Root config — applies to both backend/ and frontend/ sub-repos.
# Frontend keeps its own .editorconfig that overrides indent_size=2
# for TS/HTML; this file governs everything else.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,scala}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
