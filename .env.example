# Local development environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# To generate a JWT secret:
#   openssl rand -base64 32
#
# PR1d introduces three role-based DataSources (ADR-0002). The
# DATABASE_URL block remains the single "migrator" connection used
# by Flyway; the per-DS blocks below override the role credentials
# for the three application pools. In a dev database created with
# docker/initdb/01-create-roles.sql the defaults below line up
# with the docker-compose Postgres init script.

# ---- Database (migrator role, used by Flyway) ----
DATABASE_URL=jdbc:postgresql://localhost:5432/logistics
DATABASE_USER=migrator
DATABASE_PASSWORD=migrator

# ---- Three application DataSources (PR1d) ----
# Each can fall back to DATABASE_URL; override per role if your
# environment has separate Postgres users.
COMPANY_DATABASE_URL=
COMPANY_DATABASE_USER=app_user
COMPANY_DATABASE_PASSWORD=app_user

SYSTEM_DATABASE_URL=
SYSTEM_DATABASE_USER=app_admin
SYSTEM_DATABASE_PASSWORD=app_admin

PLATFORM_DATABASE_URL=
PLATFORM_DATABASE_USER=app_platform
PLATFORM_DATABASE_PASSWORD=app_platform

# ---- JWT (HS256) ----
# Base64-encoded secret. MUST be at least 32 bytes (256 bits) after
# decoding. `openssl rand -base64 32` produces a safe value.
JWT_SECRET=ZGV2LW9ubHktand0LXNlY3JldC1jaGFuZ2UtbWUtaW4tcHJvZC1iYXNlNjQ=

# ---- Sentry (optional in dev) ----
SENTRY_DSN=

# ---- Spring profile ----
SPRING_PROFILES_ACTIVE=dev
